   ],
   "source": [
    "import pandas as pd\n",
    "\n",
    "df = pd.read_csv(\"../data/application_train_features.csv\")\n",
    "\n",
    "# Take 500 high risk, 500 low risk, 200 borderline\n",
    "high_risk   = df[df[\"TARGET\"] == 1].sample(500, random_state=42)\n",
    "low_risk    = df[df[\"TARGET\"] == 0].sample(500, random_state=42)\n",
    "\n",
    "import pickle, numpy as np\n",
    "with open(\"../data/credit_model.pkl\", \"rb\") as f:\n",
    "    model = pickle.load(f)\n",
    "with open(\"../data/feature_list.pkl\", \"rb\") as f:\n",
    "    features = pickle.load(f)\n",
    "\n",
    "scores = model.predict_proba(df[features])[:, 1]\n",
    "borderline_mask = (scores > 0.48) & (scores < 0.58)\n",
    "borderline = df[borderline_mask].sample(200, random_state=42)\n",
    "\n",
    "sample_df = pd.concat([high_risk, low_risk, borderline]).drop_duplicates()\n",
    "sample_df.to_csv(\"../data/app_sample.csv\", index=False)\n",
    "print(\"Saved:\", sample_df.shape)\n",
    "print(\"Default rate:\", sample_df[\"TARGET\"].mean().round(3))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "40f90a12-947a-476c-a030-f668c61953b5",
