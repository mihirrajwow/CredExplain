   "source": [
    "import pandas as pd\n",
    "import pickle\n",
    "\n",
    "with open(\"../data/feature_list.pkl\", \"rb\") as f:\n",
    "    features = pickle.load(f)\n",
    "\n",
    "df = pd.read_csv(\"../data/app_sample.csv\")\n",
    "\n",
    "missing = [f for f in features if f not in df.columns]\n",
    "print(f\"Missing columns: {len(missing)}\")\n",
    "print(missing)"
   ]
