   ],
   "source": [
    "import pickle\n",
    "import xgboost as xgb\n",
    "\n",
    "# Load your existing model\n",
    "with open(\"../data/credit_model.pkl\", \"rb\") as f:\n",
    "    model = pickle.load(f)\n",
    "\n",
    "# Save in XGBoost native format — version independent\n",
    "model.save_model(\"../data/credit_model.json\")\n",
    "\n",
    "# Features list is fine with pickle protocol 2\n",
    "with open(\"../data/feature_list.pkl\", \"rb\") as f:\n",
    "    features = pickle.load(f)\n",
    "\n",
    "import pickle\n",
    "with open(\"../data/feature_list_compat.pkl\", \"wb\") as f:\n",
    "    pickle.dump(features, f, protocol=2)\n",
    "\n",
    "print(\"✅ Saved credit_model.json and feature_list_compat.pkl\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "b2862dc4-a337-4dd0-824d-24847a145631",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Saved feature_list.txt\n",
      "['ANNUITY_TO_INCOME', 'CREDIT_TO_INCOME', 'CREDIT_TO_GOODS', 'EMPLOYMENT_RATIO', 'INCOME_PER_PERSON', 'CHILDREN_RATIO', 'EXT_SOURCE_1', 'EXT_SOURCE_1_MISSING', 'EXT_SOURCE_2', 'EXT_SOURCE_3', 'AMT_INCOME_TOTAL', 'AMT_CREDIT', 'AMT_ANNUITY', 'DAYS_BIRTH', 'DAYS_EMPLOYED', 'DAYS_EMPLOYED_MISSING', 'CNT_CHILDREN', 'CNT_FAM_MEMBERS', 'NAME_CONTRACT_TYPE_ENC', 'CODE_GENDER_ENC', 'NAME_INCOME_TYPE_ENC', 'NAME_EDUCATION_TYPE_ENC', 'NAME_FAMILY_STATUS_ENC', 'OCCUPATION_TYPE_ENC', 'DOCUMENT_COUNT', 'CONTACT_REACHABILITY']\n"
     ]
    }
   ],
   "source": [
    "import pickle\n",
    "\n",
    "with open(\"../data/feature_list.pkl\", \"rb\") as f:\n",
    "    features = pickle.load(f)\n",
    "\n",
    "# Save as plain text — one feature name per line\n",
    "with open(\"../data/feature_list.txt\", \"w\") as f:\n",
    "    for feat in features:\n",
    "        f.write(feat + \"\\n\")\n",
    "\n",
    "print(\"✅ Saved feature_list.txt\")\n",
    "print(features)"
   ]
  },
